{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crawl Crew",
  "version": "0.1.0",
  "identifier": "me.pperduta.crawlcrew",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Crawl Crew",
        "width": 1120,
        "height": 700,
        "minWidth": 940,
        "minHeight": 600,
        "visible": false,
        "backgroundColor": "#0e1018"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
