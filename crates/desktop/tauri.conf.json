{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crawl Crew",
  "identifier": "me.pperduta.crawlcrew",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Crawl Crew",
        "width": 1120,
        "height": 700,
        "minWidth": 940,
        "minHeight": 600,
        "visible": false,
        "backgroundColor": "#0e1018"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4MzJEN0UzQTMwQUVBQzgKUldUSTZncWo0OWN5MkVSQVAyZGdIZGFhUjBiVGNTc1gxVldFbm1mRDEwS0lBcVRlSXVDZGpUalcK",
      "endpoints": [
        "https://github.com/perduta/lol-crawler/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
